<div class="view view--{{ size }}">
  <div class="grid grid--cols-12">
    <div class="layout layout--col layout--stretch col--span-5">
      <div class="flex flex--col flex--left flex--top">
        <div class="label label--inverted p--2 flex flex--col flex--left stretch-x">
          <span class="value value--xsmall flex p--2 pb--0">{{ today_date }}</span>
          <span class="value p--2 pt--0 stretch-x">{{ today_day }}</span>
        </div>

        <!-- Today's events -->
        <div class="mt--2" data-list-limit="true" data-list-max-height="auto" data-list-hidden-count="true">
          {% assign t_count = 0 %}
          {% for event in events %}
            {% assign ev_date = event.DTSTART | date: '%Y-%m-%d' %}
            {% if ev_date == today_iso %}
              {% if t_count >= 5 %}{% break %}{% endif %}

              {% assign st = event.DTSTART | date: '%H:%M' %}
              {% assign is_all_day = false %}
              {% unless event.DTSTART contains 'T' -%}
                {%- assign is_all_day = true -%}
              {%- elsif st == '00:00' -%}
                {%- assign is_all_day = true -%}
              {%- endunless %}

              <div class="item mb--4 mt--2">
                <div class="meta"></div>
                <div class="content flex flex--col flex--left pt--1 pb--1">
                  {% unless is_all_day %}
                    <span class="value value--small mb--0.5">{{ st }}</span>
                  {% endunless %}
                  <span class="title">
                    {{ event.SUMMARY | truncate: 28 }}
                  </span>
                </div>
              </div>
              {% assign t_count = t_count | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="stretch"></div>

      <!-- Current weather -->
      <div class="flex flex--row flex--left flex--bottom stretch-x">
        <div>
          <span class="value value--small flex flex--left flex--center gap--small">
            <img class="w--9" src="https://zoltan.co/rpi-dash/images/weather/{{ IDX_0.current.weather_code }}.svg">
            {{ IDX_0.current.temperature_2m }}&deg;
          </span>
        </div>
        <div class="stretch"></div>
        <div class="text--right pb--1">
          <span class="title title--small"
            >Min: {{ IDX_0.daily.temperature_2m_min[0] }}&deg; Max: {{ IDX_0.daily.temperature_2m_max[0] }}&deg;</span
          >
        </div>
      </div>
    </div>

    <!-- Upcoming events -->
    <div class="layout layout--col layout--top col--span-7 border--v-4 pl--3 flex flex--left">
      <div
        class="layout layout--col layout--top flex flex--left stretch-x"
        data-list-limit="true"
        data-list-max-height="auto"
        data-list-hidden-count="true"
      >
        {% assign last_date = '' %}
        {% assign s_count = 0 %}

        {% for event in events %}
          {% assign current_date = event.DTSTART | date: '%Y-%m-%d' %}

          {% if current_date > today_iso %}
            {% if s_count >= 8 %}{% break %}{% endif %}

            {% if current_date != last_date %}
              {% if last_date != '' %}</div>{% endif %}
              <div class="flex flex--col flex--left mb--2 stretch-x">
                <div class="item mb--1">
                  <div class="content flex flex--row flex--center-y gap--small">
                    {% render 'upcoming_date',
                      target_date: current_date,
                      days: days,
                      months: months,
                      tomorrow: tomorrow
                    %}
                    {% render 'weather_by_date', target_date: current_date, weather: IDX_0 %}
                  </div>
                </div>
                {% assign last_date = current_date %}
            {% endif %}

            {% assign st = event.DTSTART | date: '%H:%M' %}
            {% assign all_d = false %}
            {% unless event.DTSTART contains 'T' -%}
              {%- assign all_d = true -%}
            {%- elsif st == '00:00' -%}
              {%- assign all_d = true -%}
            {%- endunless %}

            <div class="item">
              <div class="meta"></div>
              <div class="content">
                <span class="title clamp--1">
                  {% unless all_d %}{{ st }} &ndash; {% endunless %}
                  {{ event.SUMMARY | truncate: 35 }}
                </span>
              </div>
            </div>

            {% assign s_count = s_count | plus: 1 %}
          {% endif %}
        {% endfor %}

        {% if last_date != '' %}</div>{% endif %}
      </div>

      <div class="stretch"></div>

      <div class="flex flex--row flex--center-y pb--2">
        <div class="label label--inverted bg--black p--0.5 flex flex--col">
          <div class="bg--black h--0.5 text--black">.</div>
          <span class="value value--small text--black bg--white pl--2 pr--2 text--center">
            {{ countdown_days_remaining }}
          </span>
        </div>
        <span class="title content pt--3 ml--2">{{ countdown_title }}</span>
      </div>
    </div>
  </div>
</div>
